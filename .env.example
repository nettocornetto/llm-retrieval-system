APP_NAME=story1-llm-project
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_KEY=change-me
ALLOWED_API_KEYS=change-me
DATASET_NAME=beir/scifact
DATA_DIR=./data
FAISS_INDEX_PATH=./data/indexes/faiss.index
BM25_INDEX_PATH=./data/indexes/bm25.pkl
METADATA_PATH=./data/metadata/chunks.jsonl
SQLITE_DB_PATH=./data/metadata/app.db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TOP_K=5
RETRIEVAL_K=30
USE_RERANKER=true
USE_LLM=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=30
CHUNK_SIZE_TOKENS=280
CHUNK_OVERLAP_TOKENS=40
REQUEST_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=ingest
